{
  "name": "@wyre-technology/timezest-mcp",
  "version": "1.2.0",
  "type": "module",
  "description": "MCP server for TimeZest scheduling platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "timezest-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "manifest.json"
  ],
  "scripts": {
    "build": "tsup",
    "build:ui": "vite build && node scripts/embed-ui.mjs",
    "dev": "tsx src/index.ts",
